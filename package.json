{
  "name": "git-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @git-manager/desktop dev",
    "dev:desktop": "turbo dev",
    "dev:import-repo": "bash tools/git-fixtures/dev-import.sh",
    "fixture:build": "bash tools/git-fixtures/build-all.sh",
    "build": "turbo build",
    "build:desktop": "pnpm --filter @git-manager/desktop build",
    "build:e2e": "pnpm --filter @git-manager/desktop build:e2e",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "pnpm --filter @git-manager/e2e test:e2e",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@git-manager/config": "workspace:*",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@wdio/native-utils": "^2.5.0"
    }
  },
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
