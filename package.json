{
  "name": "git-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @git-manager/desktop dev",
    "dev:desktop": "turbo dev",
    "dev:import-repo": "bash tools/git-fixtures/dev-import.sh",
    "fixture:build": "bash tools/git-fixtures/build-all.sh",
    "build": "turbo build",
    "build:desktop": "pnpm --filter @git-manager/desktop build",
    "build:e2e": "pnpm --filter @git-manager/desktop build:e2e",
    "lint": "turbo lint translation:check",
    "translation:check": "turbo translation:check",
    "test": "turbo test",
    "test:a11y": "turbo test:a11y",
    "test:e2e": "pnpm build:e2e && pnpm --filter @git-manager/e2e test:e2e",
    "test:e2e:fast": "pnpm --filter @git-manager/e2e test:e2e",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@git-manager/config": "workspace:*",
    "oxlint": "^1.73.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.3.3",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": ">=11.0.0"
  }
}
