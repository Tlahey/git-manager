{
  "name": "@git-manager/theme",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./themes.css": "./src/themes.css",
    "./themes/*.css": "./src/themes/*.css"
  },
  "scripts": {
