{
  "name": "@git-manager/ui",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./globals.css": "./src/globals.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:stories": "vitest run --project storybook && pnpm run test:apca",
    "test:storybook": "vitest run --project storybook",
    "test:apca": "vitest run --config vitest.apca.config.ts",
    "storybook": "storybook dev -p 6009",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@git-manager/theme": "workspace:*",
