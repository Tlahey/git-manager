{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "landing-page",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@git-manager/landing-page", "dev"],
      "port": 5199
    },
    {
      "name": "mascot-storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@git-manager/mascot", "storybook", "--no-open"],
      "port": 6007
    },
    {
      "name": "theme-storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@git-manager/theme", "storybook", "--no-open"],
      "port": 6008
    },
    {
      "name": "ui-storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@git-manager/ui", "storybook", "--no-open"],
      "port": 6009
    },
    {
      "name": "code-view-storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@git-manager/code-view", "storybook", "--no-open"],
      "port": 6006
    },
    {
      "name": "desktop-frontend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@git-manager/desktop", "run", "dev:frontend"],
      "port": 1420
    }
  ]
}
